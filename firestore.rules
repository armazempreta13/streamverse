rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerifiedUser() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'cintia.farinha12@gmail.com'); }
    function isAdmin() { 
      return isVerifiedUser() && (
        request.auth.token.email == 'cintia.farinha12@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128; 
    }

    function isValidContent(data) {
      return data.keys().hasAll(['title', 'slug', 'description', 'type', 'year', 'categories', 'thumbnailImage', 'coverImage', 'videoUrl', 'seasons', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() >= 0 && data.title.size() <= 1000 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() <= 1000 &&
             data.description is string && data.description.size() <= 20000 &&
             data.type is string && data.type in ['movie', 'series', 'anime'] &&
             data.year is number && data.year >= 1800 && data.year <= 2100 &&
             data.categories is list && data.categories.size() <= 50 && (data.categories.size() == 0 || data.categories[0] is string) &&
             data.thumbnailImage is string && data.thumbnailImage.size() <= 2000 &&
             data.coverImage is string && data.coverImage.size() <= 2000 &&
             data.videoUrl is string && data.videoUrl.size() <= 2000 &&
             data.seasons is number && data.seasons >= 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (data.get('sourceUrl', '') is string) && 
             (data.get('score', '') is string) && 
             (data.get('reviews', '') is string) &&
             (data.get('relevance', '') is string) &&
             (data.get('duration', '') is string) &&
             (data.get('status', '') is string) &&
             (data.get('studio', '') is string) &&
             (data.get('classification', '') is string) &&
             (data.get('audio', '') is string) &&
             (data.get('subtitles', '') is string);
    }

    match /contents/{contentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(contentId) && isValidContent(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(contentId) && isValidContent(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(contentId);

      match /episodes/{episodeId} {
        function isValidEpisode(data) {
          return data.keys().hasAll(['title', 'number', 'season', 'duration', 'thumbnailUrl', 'videoUrl', 'createdAt', 'updatedAt']) &&
                 data.title is string && data.title.size() >= 0 && data.title.size() <= 500 &&
                 data.number is number && data.number >= 0 &&
                 data.season is number && data.season >= 0 &&
                 data.duration is string && data.duration.size() <= 100 &&
                 data.thumbnailUrl is string && data.thumbnailUrl.size() <= 2000 &&
                 data.videoUrl is string && data.videoUrl.size() <= 5000 &&
                 data.createdAt is timestamp &&
                 data.updatedAt is timestamp &&
                 (data.get('sourceUrl', '') is string) &&
                 (data.get('videoUrl2', '') is string) &&
                 (data.get('iframes', []) is list);
        }

        allow read: if true;
        allow create: if isAdmin() && isValidId(episodeId) && isValidEpisode(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
        allow update: if isAdmin() && isValidId(episodeId) && isValidEpisode(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt;
        allow delete: if isAdmin() && isValidId(episodeId);
      }
    }

    match /users/{userId} {
      allow read: if isVerifiedUser() && request.auth.uid == userId || isAdmin();
      allow create: if isVerifiedUser() && request.auth.uid == userId && isValidId(userId) && incoming().keys().hasAll(['email', 'role', 'createdAt', 'updatedAt']) && incoming().keys().size() == 4 && incoming().email == request.auth.token.email && (incoming().role == 'user' || (incoming().role == 'admin' && request.auth.token.email == 'cintia.farinha12@gmail.com')) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isVerifiedUser() && request.auth.uid == userId && isValidId(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt;
      allow delete: if isVerifiedUser() && request.auth.uid == userId || isAdmin();
      
      match /watchlist/{slug} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /progress/{slug} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Comentários: qualquer pessoa pode ler e criar (sem login)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['contentId', 'userName', 'text', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() < 2000
                    && request.resource.data.userName is string
                    && request.resource.data.userName.size() > 0;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
      allow delete: if false;
    }
  }
}
